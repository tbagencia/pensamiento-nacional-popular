# Copy to .env and fill in. Hash: php -r "echo password_hash('pass', PASSWORD_DEFAULT);"
ADMIN_PASSWORD_HASH=""
DEV_MODE=false
MAIL_FROM=no-reply@yourdomain.com
MAIL_FROM_NAME="Línea de Tiempo del Pensamiento Nacional y Popular"
# smtp (Mailtrap dev) | mail (Hostinger prod)
MAIL_DRIVER=mail
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
