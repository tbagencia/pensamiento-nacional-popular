# Block web access to sensitive files (the project ships .env in the webroot
# on shared hosting, so this is mandatory).
<FilesMatch "^\.(env|env\.example|gitignore)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Hide git metadata and the test suite if the repo is deployed as-is.
RedirectMatch 404 /\.git
RedirectMatch 404 ^/tests

# Friendly URLs (assumes deployment at the domain root).
#   /linea/1945  -> timeline positioned at that year
#   /cargar      -> submission form
#   /cargar/1945 -> submission form with the year pre-filled
#   /validar/<token> -> email verification landing
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^linea/?$ / [R=302,L]
  RewriteRule ^linea/[0-9]{4}/?$ index.html [L]
  RewriteRule ^tipo/(discurso|carta|manifiesto|libro|ensayo|poema|entrevista|texto)/?$ index.html [L]
  RewriteRule ^tipo(/.*)?$ / [R=302,L]
  RewriteRule ^cargar(/[0-9]{4})?/?$ cargar.html [L]
  RewriteRule ^validar/([a-f0-9]{64})/?$ api/verify.php?token=$1 [L]
  RewriteRule ^documento/([0-9]+)/?$ api/documento.php?id=$1 [L]
  RewriteRule ^sitemap\.xml$ api/sitemap.php [L]
  RewriteRule ^panel/([A-Za-z0-9-]+)/?$ admin/index.php [L]
</IfModule>
